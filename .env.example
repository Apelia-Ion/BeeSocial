# Clerk — auth keys from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Postgres — Neon (or any Postgres) connection string used by Prisma
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# UploadThing — API token from https://uploadthing.com/dashboard → API Keys
# Used for post image uploads via /api/uploadthing
UPLOADTHING_TOKEN=
